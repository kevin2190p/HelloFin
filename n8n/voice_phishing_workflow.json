{
  "name": "HelloFin – OpenClaw Voice Phishing Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "openclaw-voice",
        "responseMode": "onReceived",
        "responseCode": 200,
        "options": {}
      },
      "id": "n1-webhook",
      "name": "OpenClaw Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 340],
      "webhookId": "openclaw-voice"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Extract data from OpenClaw webhook\nconst item = $input.first().json;\nconst body = item.body || item;\n\nconst messageType = body.message_type || 'unknown';\nconst sender = body.sender_phone || 'unknown';\nconst timestamp = body.timestamp || Date.now().toString();\nconst pushName = body.push_name || 'Unknown';\nconst text = body.text || '';\nconst duration = body.duration || 0;\n\n// Check if this is a voice note (has binary data)\nconst hasBinary = Object.keys($input.first().binary || {}).length > 0;\n\nconsole.log(`[HelloFin] Message from +${sender} (${pushName})`);\nconsole.log(`[HelloFin] Type: ${messageType}, Has Audio: ${hasBinary}`);\n\nreturn [{\n  json: {\n    message_type: messageType,\n    sender_phone: sender,\n    timestamp,\n    push_name: pushName,\n    text,\n    duration,\n    has_audio: hasBinary\n  },\n  binary: $input.first().binary\n}];"
      },
      "id": "n2-extract",
      "name": "Extract Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 340]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "combinator": "or",
          "conditions": [
            {
              "leftValue": "={{ $json.message_type }}",
              "rightValue": "voice",
              "operator": { "type": "string", "operation": "equals" }
            },
            {
              "leftValue": "={{ $json.has_audio }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      },
      "id": "n3-check-type",
      "name": "Voice or Text?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [640, 340]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/webhook/whatsapp-voice",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "parameterType": "formBinaryData",
              "name": "audio",
              "inputDataFieldName": "data"
            },
            {
              "parameterType": "formData",
              "name": "sender_phone",
              "value": "={{ $json.sender_phone }}"
            },
            {
              "parameterType": "formData",
              "name": "is_new_payee",
              "value": "false"
            },
            {
              "parameterType": "formData",
              "name": "transaction_amount",
              "value": "0"
            }
          ]
        },
        "options": {
          "timeout": 120000
        }
      },
      "id": "n4-forward-voice",
      "name": "Forward Voice to Jane",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 240],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/risk/score",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"transcript\": \"{{ $json.text }}\",\n  \"caller_number\": \"{{ $json.sender_phone }}\",\n  \"is_new_payee\": false,\n  \"transaction_amount\": 0\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "n5-forward-text",
      "name": "Score Text via Jane",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 460],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{ $json.risk_score }}",
              "rightValue": 80,
              "operator": { "type": "number", "operation": "gte" }
            }
          ]
        }
      },
      "id": "n6-risk-check",
      "name": "High Risk?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1100, 340]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/tng/hold",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"txn_id\": \"{{ $json.txn_id || $json.request_id || 'txn-' + Date.now() }}\",\n  \"risk_score\": {{ $json.risk_score }},\n  \"sender_phone\": \"{{ $json.sender_phone || 'unknown' }}\",\n  \"transaction_amount\": 0,\n  \"reason\": \"Voice phishing detected by OpenClaw + n8n\"\n}",
        "options": {}
      },
      "id": "n7-hold",
      "name": "Trigger Hold (Shawn)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, 240]
    },
    {
      "parameters": {},
      "id": "n8-low-risk",
      "name": "Low Risk (Pass)",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1320, 460]
    }
  ],
  "connections": {
    "OpenClaw Webhook": {
      "main": [[{ "node": "Extract Message", "type": "main", "index": 0 }]]
